<script>
  const fund = [
    ["Skrubtudse",       "Bufo bufo",           "Hareskoven"],
    ["Nældens takvinge", "Aglais urticae",      "Amager Fælled"],
    ["Spætmejse",        "Sitta europaea",      "Dyrehaven"],
    ["Hvid anemone",     "Anemone nemorosa",    "Rold Skov"],
    ["Alm. mariehøne",   "Coccinella 7-punctata","Mols Bjerge"],
    ["Stor vandsalamander","Triturus cristatus","Skjern Enge"],
    ["Bøg",              "Fagus sylvatica",     "Hareskoven"]
  ];

  const log = document.getElementById("log");
  const taeller = document.getElementById("taeller");
  const rolig = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  fund.forEach(([navn, latin, sted], i) => {
    const r = document.createElement("div");
    r.className = "linje";
    r.style.animationDelay = rolig ? "0s" : (0.25 + i * 0.16) + "s";
    r.innerHTML =
      '<span class="nr">' + String(i + 1).padStart(2, "0") + '</span>' +
      '<span class="art">' + navn + ' <i>' + latin + '</i></span>' +
      '<span class="sted">' + sted + '</span>';
    log.appendChild(r);
  });

  // Tælleren følger listen, så tallet betyder noget i stedet for at pynte.
  let n = 0;
  const tik = () => {
    n++;
    taeller.textContent = n + (n === 1 ? " art" : " arter");
    if (n < fund.length) setTimeout(tik, 160);
  };
  rolig ? (taeller.textContent = fund.length + " arter") : setTimeout(tik, 400);
</script>

