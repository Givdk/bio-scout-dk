  if(!fil) return;
  e.target.value = '';

  vis('trin-arbejder');
  $('arbejderTekst').textContent = 'Tjekker forbindelsen…';

  // Appen spørger ikke, hvilket udstyr den kører på. Den spørger nettet.
  const online = await erOnline();

  if(!online){
    // Ingen forbindelse: billedet skaleres ned og lægges i kø på selve enheden.
    try{
      await gemIKoe(fil, {
        tilstand, trin:S.trin, omraade:S.omraade,
        missionId:S.mission?.id, stedId:S.sted
      });
      const n = await antalIKoe();
      $('gemtTekst').textContent =
        n === 1
