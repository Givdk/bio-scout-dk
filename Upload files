
<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bio-Scout</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Karla:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --skovbund:#17281B;
    --mos:#456B4C;
    --mos-lys:#6B9473;
    --lav:#CBD6C2;
    --papir:#EDF0E4;
    --papir-dyb:#E2E7D6;
    --roen:#C2452A;
    --bark:#6E5A44;
    --display:'Fraunces',Georgia,serif;
    --brod:'Karla',system-ui,sans-serif;
    --log:'Space Mono',ui-monospace,monospace;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-text-size-adjust:100%}
  body{
    background:var(--papir);color:var(--skovbund);font-family:var(--brod);
    font-size:17px;line-height:1.55;min-height:100vh;
    display:flex;flex-direction:column;
  }
  .wrap{width:100%;max-width:820px;margin:0 auto;padding:0 24px}

  /* header */
  header{border-bottom:1px solid var(--lav);padding:18px 0;background:var(--papir)}
  .hrow{display:flex;justify-content:space-between;align-items:center;gap:16px}
  .maerke{display:flex;align-items:baseline;gap:9px;text-decoration:none;color:inherit}
  .maerke b{font-family:var(--display);font-weight:700;font-size:19px;letter-spacing:-.01em}
  .maerke span{font-family:var(--log);font-size:9.5px;letter-spacing:.15em;
    text-transform:uppercase;color:var(--mos)}
  .hknap{
    font-family:var(--log);font-size:10px;letter-spacing:.12em;text-transform:uppercase;
    background:none;border:1px solid var(--lav);color:var(--bark);
    padding:7px 13px;border-radius:2px;cursor:pointer;
  }
  .hknap:hover{border-color:var(--mos);color:var(--mos)}

  main{flex:1;padding:36px 0 60px}

  /* generelle elementer */
  h1{font-family:var(--display);font-weight:600;font-size:clamp(1.9rem,4.4vw,2.7rem);
    line-height:1.08;letter-spacing:-.02em;margin-bottom:12px;
    font-variation-settings:'SOFT' 40,'WONK' 1}
  h2{font-family:var(--display);font-weight:600;font-size:1.45rem;
    line-height:1.15;letter-spacing:-.015em;margin-bottom:10px}
  .manchet{color:#3B4E39;margin-bottom:28px;max-width:52ch}
  .eyebrow{font-family:var(--log);font-size:10px;letter-spacing:.15em;
    text-transform:uppercase;color:var(--mos);margin-bottom:10px}

  .knap{
    font-family:var(--brod);font-weight:700;font-size:1rem;
    background:var(--mos);color:#fff;border:none;
    padding:13px 26px;border-radius:2px;cursor:pointer;
    transition:background .16s ease;
  }
  .knap:hover{background:var(--skovbund)}
  .knap:disabled{background:var(--lav);color:#8A9683;cursor:not-allowed}
  .knap--roed{background:var(--roen)}
  .knap--roed:hover{background:#9E3520}
  .knap--stille{background:none;color:var(--bark);border:1px solid var(--lav);
    font-weight:500;padding:11px 20px}
  .knap--stille:hover{background:none;border-color:var(--mos);color:var(--mos)}
  button:focus-visible,a:focus-visible,label:focus-within{
    outline:2px solid var(--mos);outline-offset:3px}

  .kort{background:#fff;border:1px solid var(--lav);border-radius:4px;padding:24px}

  /* valgknapper */
  .valg{display:grid;gap:12px;margin-bottom:30px}
  .valg--2{grid-template-columns:1fr 1fr}
  .valg--4{grid-template-columns:repeat(4,1fr)}
  .vkort{
    background:#fff;border:1px solid var(--lav);border-radius:4px;
    padding:18px;text-align:left;cursor:pointer;font-family:var(--brod);
    color:inherit;font-size:1rem;transition:border-color .16s,transform .16s;
  }
  .vkort:hover{border-color:var(--mos);transform:translateY(-2px)}
  .vkort.valgt{border-color:var(--mos);border-width:2px;padding:17px}
  .vkort b{display:block;font-family:var(--display);font-weight:600;
    font-size:1.12rem;margin-bottom:4px}
  .vkort small{color:var(--bark);font-size:.83rem;line-height:1.4;display:block}
  .vkort .ikon{font-size:1.5rem;display:block;margin-bottom:8px}

  /* mission */
  .mission{
    background:#fff;border:1px solid var(--lav);border-left:4px solid var(--roen);
    border-radius:4px;padding:26px;margin-bottom:22px;
  }
  .mission .ikon{font-size:2.3rem;display:block;margin-bottom:12px}
  .mission h2{margin-bottom:8px}
  .mission p{font-size:1.1rem;margin-bottom:14px}
  .mission .meta{font-family:var(--log);font-size:10.5px;letter-spacing:.1em;
    text-transform:uppercase;color:var(--bark)}

  /* kamera */
  .drop{
    border:2px dashed var(--lav);border-radius:4px;background:#fff;
    padding:44px 24px;text-align:center;cursor:pointer;display:block;
    transition:border-color .16s,background .16s;
  }
  .drop:hover{border-color:var(--mos);background:#fbfcfa}
  .drop .ikon{font-size:2.6rem;display:block;margin-bottom:12px}
  .drop b{font-family:var(--display);font-size:1.2rem;font-weight:600;
    display:block;margin-bottom:6px}
  .drop small{color:var(--bark);font-size:.88rem}
  input[type=file]{position:absolute;width:1px;height:1px;opacity:0;overflow:hidden}

  /* status / fejl */
  .status{
    display:flex;align-items:center;gap:12px;padding:16px 20px;
    background:#fff;border:1px solid var(--lav);border-radius:4px;margin-bottom:18px;
  }
  .spinner{
    width:17px;height:17px;border:2px solid var(--lav);border-top-color:var(--mos);
    border-radius:50%;animation:snurr .7s linear infinite;flex-shrink:0;
  }
  @keyframes snurr{to{transform:rotate(360deg)}}
  .advarsel{
    background:#FBEAE6;border:1px solid #E8BCB2;border-left:4px solid var(--roen);
    border-radius:4px;padding:18px 20px;margin-bottom:20px;
  }
  .advarsel b{display:block;margin-bottom:5px;font-family:var(--display);font-size:1.1rem}
  .advarsel p{font-size:.94rem;color:#6B3325}

  /* resultat */
  .art-navn{font-family:var(--display);font-weight:700;
    font-size:clamp(1.7rem,4vw,2.3rem);letter-spacing:-.02em;line-height:1.08}
  .art-latin{font-style:italic;color:var(--bark);font-size:1rem;margin-bottom:14px}
  .maerkat{
    display:inline-block;font-family:var(--log);font-size:9.5px;letter-spacing:.12em;
    text-transform:uppercase;padding:4px 10px;border-radius:2px;
    background:var(--papir-dyb);color:var(--bark);margin-right:6px;
  }
  .maerkat--lav{background:#FBEAE6;color:#9E3520}
  .fakta{
    background:var(--papir-dyb);border-radius:3px;padding:14px 16px;
    margin-top:16px;font-size:.96rem;
  }
  .fakta b{font-family:var(--log);font-size:9.5px;letter-spacing:.13em;
    text-transform:uppercase;color:var(--mos);display:block;margin-bottom:5px}

  /* spørgsmål */
  .spm{
    background:#fff;border:1px solid var(--lav);border-left:4px solid var(--mos);
    border-radius:4px;padding:24px;margin:22px 0;
  }
  .spm .tekst{font-family:var(--display);font-weight:600;font-size:1.3rem;
    line-height:1.3;letter-spacing:-.01em}
  .maal{
    font-family:var(--log);font-size:10px;letter-spacing:.1em;text-transform:uppercase;
    color:var(--bark);border-top:1px dotted var(--lav);
    padding-top:12px;margin-top:16px;line-height:1.6;
  }

  textarea{
    width:100%;font-family:var(--brod);font-size:1.02rem;line-height:1.5;
    padding:15px;border:1px solid var(--lav);border-radius:3px;
    background:#fff;color:inherit;resize:vertical;min-height:110px;
  }
  textarea:focus{outline:2px solid var(--mos);outline-offset:1px;border-color:var(--mos)}
  .hint{font-size:.84rem;color:var(--bark);margin-top:8px}

  .raekke{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-top:16px}

  /* feedback */
  .respons{
    background:#fff;border:1px solid var(--lav);border-left:4px solid var(--mos-lys);
    border-radius:4px;padding:24px;margin-bottom:18px;
  }
  .respons p{margin-bottom:14px}
  .respons p:last-child{margin-bottom:0}
  .naeste{font-family:var(--display);font-weight:600;font-size:1.15rem;
    color:var(--mos);line-height:1.3}
  .laerernote{
    background:var(--papir-dyb);border-radius:3px;padding:13px 15px;
    font-size:.9rem;margin-top:16px;
  }
  .laerernote b{font-family:var(--log);font-size:9.5px;letter-spacing:.13em;
    text-transform:uppercase;color:var(--bark);display:block;margin-bottom:5px}

  /* samling */
  .samling{border-top:1px solid var(--lav);margin-top:44px;padding-top:24px}
  .samling-top{display:flex;justify-content:space-between;align-items:baseline;
    margin-bottom:14px;gap:16px;flex-wrap:wrap}
  .samling-top h3{font-family:var(--display);font-weight:600;font-size:1.2rem}
  .samling-tal{font-family:var(--log);font-size:11px;letter-spacing:.1em;
    text-transform:uppercase;color:var(--mos);font-weight:700}
  .liste{display:grid;gap:0}
  .linje{
    display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:baseline;
    font-family:var(--log);font-size:12.5px;padding:8px 0;
    border-bottom:1px dotted rgba(107,90,68,.28);
  }
  .linje:last-child{border-bottom:none}
  .linje .nr{color:var(--bark);font-size:11px}
  .linje .n{font-weight:700;letter-spacing:-.01em}
  .linje .a{color:var(--mos);font-size:11px;white-space:nowrap}
  .tom{color:var(--bark);font-size:.92rem;padding:8px 0}

  .koestatus{
    font-family:var(--log);font-size:9.5px;letter-spacing:.1em;
    text-transform:uppercase;background:var(--papir-dyb);color:var(--bark);
    border:1px solid var(--lav);padding:6px 11px;border-radius:2px;
  }
  .koestatus.venter{border-color:var(--accent,#C2452A);color:#C2452A}

  .banner{
    display:flex;align-items:center;gap:12px;flex-wrap:wrap;
    background:var(--papir-dyb);border:1px solid var(--lav);
    border-left:4px solid var(--bark);border-radius:4px;
    padding:15px 18px;margin-bottom:20px;font-size:.94rem;
  }
  .banner b{font-family:var(--display);font-size:1.05rem;display:block}
  .banner--klar{border-left-color:var(--mos)}

  .gemt{
    text-align:center;padding:40px 24px;background:#fff;
    border:1px solid var(--lav);border-radius:4px;
  }
  .gemt .ikon{font-size:3rem;display:block;margin-bottom:14px}
  .gemt b{font-family:var(--display);font-weight:600;font-size:1.5rem;
    display:block;margin-bottom:8px}
  .gemt p{color:var(--bark);max-width:38ch;margin:0 auto 20px}

  .skjul{display:none !important}

  @media (max-width:700px){
    .valg--4{grid-template-columns:1fr 1fr}
    .wrap{padding:0 18px}
  }
  @media (max-width:440px){
    .valg--2,.valg--4{grid-template-columns:1fr}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation-duration:.01ms !important;transition-duration:.01ms !important}
  }
</style>
</head>
<body>

<header>
  <div class="wrap hrow">
    <a class="maerke" href="index.html">
      <b>Bio-Scout</b><span id="tilstandMaerke">Skole</span>
    </a>
    <div style="display:flex;gap:8px;align-items:center">
      <span class="koestatus skjul" id="koeStatus"></span>
      <button class="hknap" id="startForfra">Forfra</button>
    </div>
  </div>
</header>

<main class="wrap">

  <!-- TRIN: sted -->
  <section id="trin-sted" class="skjul">
    <div class="eyebrow" id="stedEyebrow"></div>
    <h1>Hvor er I henne?</h1>
    <p class="manchet">Stedet gør artsbestemmelsen mere præcis — og giver jer
      missioner, der kun findes lige der.</p>
    <div class="valg valg--2" id="stedValg"></div>
  </section>

  <!-- TRIN: klassetrin (kun skole) -->
  <section id="trin-klassetrin" class="skjul">
    <div class="eyebrow">Undervisning</div>
    <h1>Hvilket klassetrin?</h1>
    <p class="manchet">Spørgsmål, sprog og respons tilpasses trinnet.</p>
    <div class="valg valg--4" id="trinValg"></div>
  </section>

  <!-- TRIN: kompetenceområde (kun skole) -->
  <section id="trin-omraade" class="skjul">
    <div class="eyebrow" id="omraadeEyebrow">Undervisning</div>
    <h1>Hvad skal I arbejde med?</h1>
    <p class="manchet">De fire kompetenceområder fra Fælles Mål. Vælg ét — I kan
      tage de andre på næste tur.</p>
    <div class="valg valg--2" id="omraadeValg"></div>
  </section>

  <!-- TRIN: mission (kun fritid) -->
  <section id="trin-mission" class="skjul">
    <div class="eyebrow">Fritid</div>
    <h1>Dagens mission</h1>
    <div class="mission" id="missionKort"></div>
    <div class="raekke">
      <button class="knap knap--roed" id="missionStart">Vi tager den</button>
      <button class="knap knap--stille" id="missionSkift">Giv mig en anden</button>
    </div>
  </section>

  <!-- TRIN: foto -->
  <section id="trin-foto" class="skjul">
    <div class="eyebrow" id="fotoEyebrow"></div>
    <h1 id="fotoOverskrift">Tag et billede af jeres fund</h1>
    <p class="manchet" id="fotoManchet">
      Fotografér dyret eller planten så tæt på som muligt. Billedet bliver
      brugt til at genkende arten og bliver ikke gemt nogen steder.
    </p>
    <label class="drop" for="filInput" tabindex="0">
      <span class="ikon">🌿</span>
      <b>Tag billede eller vælg fra galleriet</b>
      <small>Kun natur, dyr og planter — ikke personer</small>
    </label>
    <input type="file" id="filInput" accept="image/*" capture="environment">
  </section>

  <!-- TRIN: arbejder -->
  <section id="trin-arbejder" class="skjul">
    <div class="status">
      <div class="spinner"></div>
      <span id="arbejderTekst">Kigger på billedet…</span>
    </div>
  </section>

  <!-- TRIN: gemt til senere -->
  <section id="trin-gemt" class="skjul">
    <div class="gemt">
      <span class="ikon">🎒</span>
      <b>Fundet er gemt</b>
      <p id="gemtTekst">I er offline lige nu. Fundet bliver bestemt, så snart
        I er tilbage på wifi.</p>
      <button class="knap" id="gemtVidere">Find noget mere</button>
    </div>
  </section>

  <!-- TRIN: resultat + spørgsmål -->
  <section id="trin-resultat" class="skjul">
    <div id="advarselBoks"></div>
    <div class="kort" id="artKort"></div>
    <div class="spm" id="spmKort"></div>

    <label for="svarFelt" class="eyebrow">Jeres svar</label>
    <textarea id="svarFelt" placeholder="Skriv hvad I tænker…"></textarea>
    <p class="hint">Skriv om dyret eller planten — ikke om jer selv eller
      hinandens navne.</p>

    <div class="raekke">
      <button class="knap" id="sendSvar">Send svar</button>
      <button class="knap knap--stille" id="visHjaelp">Jeg er gået i stå</button>
      <button class="knap knap--stille skjul" id="talKnap">🎤 Sig det i stedet</button>
    </div>
    <div id="hjaelpBoks"></div>
  </section>

  <!-- TRIN: respons -->
  <section id="trin-respons" class="skjul">
    <div class="respons" id="responsKort"></div>
    <div class="raekke">
      <button class="knap" id="nyttFund">Find noget nyt</button>
      <button class="knap knap--stille" id="skiftOpgave">Ny opgave, samme fund</button>
    </div>
  </section>

  <!-- SAMLING -->
  <section class="samling" id="samlingSektion">
    <div class="samling-top">
      <h3 id="samlingTitel">Klassens liste</h3>
      <span class="samling-tal" id="samlingTal">0 arter</span>
    </div>
    <div class="liste" id="samlingListe"></div>
  </section>

</main>

<script type="module">
import {
  TILSTAND, KLASSETRIN, KOMPETENCEOMRAADER, MISSIONER,
  vaelgMission, byggIdentifikationsPrompt, byggSkoleopgave,
  byggFritidsspoergsmaal, byggSkolefeedback, byggFritidssvar,
  parseJSON, opdaterSamling, samlingsStatus, naesteOmraade
} from './opgaver.js';

import { alleSteder, hentSted, missionerForSted, stedTilPrompt, vidsteDu }
  from './steder.js';

import { gemIKoe, antalIKoe, ryddKoe, erOnline, lytTilForbindelse, afvikleKoe,
         nedskalerBillede } from './offline.js';

// ---------------------------------------------------------------------------
// TILSTAND
// ---------------------------------------------------------------------------
const params = new URLSearchParams(location.search);
const tilstand = params.get('tilstand') === 'fritid' ? TILSTAND.FRITID : TILSTAND.SKOLE;
const erSkole = tilstand === TILSTAND.SKOLE;

const S = {
  sted: null,
  trin: null,
  omraade: null,
  mission: null,
  art: null,
  opgave: null,
  brugteOmraader: [],
  samling: [],
};

// ---------------------------------------------------------------------------
// LAGRING — overlever refresh, men gemmer kun artsnavne. Aldrig billeder,
// aldrig elevsvar, aldrig noget personhenførbart.
// ---------------------------------------------------------------------------
const NOEGLE = 'bioscout-samling-' + tilstand;

function hentSamling(){
  try{
    const raa = localStorage.getItem(NOEGLE);
    return raa ? JSON.parse(raa) : [];
  }catch(e){ return []; }         // privat browsing e.l. — kør videre i hukommelsen
}
function gemSamling(){
  try{ localStorage.setItem(NOEGLE, JSON.stringify(S.samling)); }catch(e){}
}

// ---------------------------------------------------------------------------
// HJÆLPERE
// ---------------------------------------------------------------------------
const $ = id => document.getElementById(id);
const TRIN_IDS = ['trin-sted','trin-klassetrin','trin-omraade','trin-mission',
                  'trin-foto','trin-arbejder','trin-gemt','trin-resultat',
                  'trin-respons'];

function vis(id){
  TRIN_IDS.forEach(t => $(t).classList.add('skjul'));
  if(id) $(id).classList.remove('skjul');
  window.scrollTo({top:0, behavior:'smooth'});
}

async function kald(sti, krop){
  const r = await fetch(sti, {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(krop)
  });
  if(!r.ok){
    const t = await r.text().catch(()=> '');
    throw new Error('Serveren svarede ' + r.status + '. ' + t.slice(0,120));
  }
  return r.json();
}

async function spoergClaude(prompt){
  const data = await kald('/api/claude', { messages:[{role:'user', content:prompt}] });
  if(data.error) throw new Error(data.error.message || 'Ukendt fejl fra Claude');
  const tekst = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('\n');
  return parseJSON(tekst);
}

async function spoergGemini(prompt, base64){
  const data = await kald('/api/scan', { prompt, base64 });
  if(data.error) throw new Error(data.error.message || 'Ukendt fejl fra Gemini');
  const tekst = data.candidates?.[0]?.content?.parts?.[0]?.text;
  if(!tekst) throw new Error('Tomt svar fra billedgenkendelsen');
  return parseJSON(tekst);
}

function fejlboks(besked, hvad){
  return `<div class="advarsel">
    <b>${besked}</b>
    <p>${hvad}</p>
  </div>`;
}

// ---------------------------------------------------------------------------
// OPSÆTNING AF TILSTAND
// ---------------------------------------------------------------------------
$('tilstandMaerke').textContent = erSkole ? 'Skole' : 'SFO / klub';
$('samlingTitel').textContent   = erSkole ? 'Klassens liste' : 'Klubbens liste';
$('fotoEyebrow').textContent    = erSkole ? 'Undervisning' : 'Fritid';

if(!erSkole){
  $('fotoOverskrift').textContent = 'Hvad fandt I?';
  $('fotoManchet').textContent =
    'Tag et billede af det, I har fundet. Billedet bliver kun brugt til at ' +
    'genkende arten — det bliver ikke gemt.';
}

// Byg klassetrinvalg
Object.entries(KLASSETRIN).forEach(([id, k]) => {
  const b = document.createElement('button');
  b.className = 'vkort';
  b.innerHTML = `<b>${k.label}</b><small>${k.fag}</small>`;
  b.onclick = () => { S.trin = id; visOmraader(); };
  $('trinValg').appendChild(b);
});

function visOmraader(){
  const k = KLASSETRIN[S.trin];
  $('omraadeEyebrow').textContent = k.label + ' · ' + k.fag;
  const box = $('omraadeValg');
  box.innerHTML = '';
  Object.entries(KOMPETENCEOMRAADER).forEach(([id, o]) => {
    const b = document.createElement('button');
    b.className = 'vkort' + (S.brugteOmraader.includes(id) ? '' : '');
    b.innerHTML = `<span class="ikon">${o.ikon}</span><b>${o.label}</b>
                   <small>${o.laeringsmaal[S.trin]}</small>`;
    b.onclick = () => { S.omraade = id; vis('trin-foto'); };
    box.appendChild(b);
  });
  vis('trin-omraade');
}

function visMission(){
  const pulje = missionerForSted(S.sted, MISSIONER);
  const m = S.mission = pulje[Math.floor(Math.random() * pulje.length)];
  $('missionKort').innerHTML = `
    <span class="ikon">${m.ikon}</span>
    <h2>${m.titel}</h2>
